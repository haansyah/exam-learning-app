    {
      "id": "q1",
      "text": "Ubah ke reported speech: 'I am tired,' she said. → She said that she ___ tired.",
      "options": [
        {
          "id": "a",
          "text": "is"
        },
        {
          "id": "b",
          "text": "was"
        },
        {
          "id": "c",
          "text": "am"
        },
        {
          "id": "d",
          "text": "were"
        }
      ],
      "correctOptionId": "b",
      "explanation": "Present → past dalam reported speech: am/is → was."
    },
    {
